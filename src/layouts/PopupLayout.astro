---
import '@/styles/globals.css';

interface Props {
  title?: string;
}

const { title = 'Arknights Sign-in Butler' } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>